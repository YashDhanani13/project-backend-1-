generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  organizationName String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  users            User[]
  contacts         Contact[]
  employees        Employee[]
}

model User {
  id             Int        @id @default(autoincrement())
  fullName       String
  email          String     @unique
  password       String
  organizationId Int
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization      Organization @relation(fields: [organizationId], references: [id])
  contactsCreated   Contact[]    @relation("ContactCreatedBy")  contacts this user created
  contactsUpdated   Contact[]    @relation("ContactUpdatedBy")  contacts this user updated
  employeesCreated  Employee[]   @relation("EmployeeCreatedBy")  employees this user created
  employeesUpdated  Employee[]   @relation("EmployeeUpdatedBy")  employees this user updated
} 

model Contact {
  
  id             Int       @id @default(autoincrement())
  name           String
  email          String    @unique
  age            Int?
  phoneNumber    String?
  address        String?
  tag            Tag?
  organizationId Int

  createdBy      Int  
  updatedBy      Int?      

  createdAt      DateTime  @default(now()) 
  updatedAt      DateTime  @updatedAt  
  
  organization    Organization @relation(fields: [organizationId], references: [id])
  createdByUser   User         @relation("ContactCreatedBy", fields: [createdBy], references: [id])
  updatedByUser   User?        @relation("ContactUpdatedBy", fields: [updatedBy], references: [id])
}

model Employee {
  id             Int            @id @default(autoincrement())
  name           String
  email          String         @unique
  role           EmployeeRole
  phoneNumber    String
  status         EmployeeStatus @default(ACTIVE)
  organizationId Int

  createdBy      Int           
  updatedBy      Int?        

  createdAt      DateTime       @default(now())  // ✅ auto
  updatedAt      DateTime       @updatedAt        // ✅ auto

  organization    Organization @relation(fields: [organizationId], references: [id])
  createdByUser   User         @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  updatedByUser   User?        @relation("EmployeeUpdatedBy", fields: [updatedBy], references: [id])
}

enum Tag {
  VIP
  VVIP
  regular
}


enum EmployeeRole {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE b
}