generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               Int      @id @default(autoincrement())
  organizationName String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users     User[]
  contacts  Contact[]
  employees Employee[]
  userRooms UserRoom[]
  rooms     Room[]
    conversations Conversation[]  
}

model User {
  id             Int      @id @default(autoincrement())
  fullName       String
  email          String   @unique
  password       String
  organizationId Int
  profileImage   String?
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id])

  contactsCreated  Contact[]  @relation("ContactCreatedBy")
  contactsUpdated  Contact[]  @relation("ContactUpdatedBy")

  employeesCreated Employee[] @relation("EmployeeCreatedBy")
  employeesUpdated Employee[] @relation("EmployeeUpdatedBy")

  messages         Message[]  @relation("MessageSentBy")
  messagesUpdated  Message[]  @relation("MessageUpdatedBy")

  userRooms        UserRoom[] @relation("UserRoomMember")
  userRoomsCreated UserRoom[] @relation("UserRoomCreatedBy")

  roomsCreated     Room[]     @relation("RoomCreatedBy") // ✅ Fixed missing relation
}

model Contact {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  age            Int?
  phoneNumber    String?
  address        String?
  tag            Tag?
  organizationId Int
  createdBy      Int
  updatedBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
      conversation  Conversation?

  organization  Organization @relation(fields: [organizationId], references: [id])
  createdByUser User         @relation("ContactCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?        @relation("ContactUpdatedBy", fields: [updatedBy], references: [id])
}

model Employee {
  id             Int            @id @default(autoincrement())
  name           String
  email          String         @unique
  role           EmployeeRole
  phoneNumber    String
  status         EmployeeStatus @default(ACTIVE)
  organizationId Int
  createdBy      Int
  updatedBy      Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id])
  createdByUser User         @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?        @relation("EmployeeUpdatedBy", fields: [updatedBy], references: [id])
}

model Message {
  id        Int          @id @default(autoincrement())
  text      String
  type      MessageType  @default(TEXT)  // ✅ Added message type
  roomId    Int
  senderId  Int
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  updatedBy Int?
  deletedAt DateTime?
  deletedBy Int?

  room          Room  @relation(fields: [roomId], references: [id])
  sender        User  @relation("MessageSentBy", fields: [senderId], references: [id])
  updatedByUser User? @relation("MessageUpdatedBy", fields: [updatedBy], references: [id])
}

model UserRoom {
  id             Int      @id @default(autoincrement())
  userId         Int
  organizationId Int
  roomId         Int
  unreadMessageCount Int  @default(0)  // ✅ Moved from Room → per-user count
  createdAt      DateTime @default(now())
  createdBy      Int
  updatedAt      DateTime @updatedAt
  updatedBy      Int?

  user          User         @relation("UserRoomMember", fields: [userId], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])
  room          Room         @relation(fields: [roomId], references: [id])
  createdByUser User         @relation("UserRoomCreatedBy", fields: [createdBy], references: [id])

  @@unique([userId, roomId])
}

model Room {
  id             Int       @id @default(autoincrement())
  organizationId Int
  name           String?   // ✅ Added — null for DMs, set for group chats
  type           RoomType  @default(DIRECT)  // ✅ Added — DM vs Group
  lastMessageAt  DateTime?
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  createdBy      Int
  updatedAt      DateTime  @updatedAt
  updatedBy      Int?
    conversation  Conversation?
  organization  Organization @relation(fields: [organizationId], references: [id])
  createdByUser User         @relation("RoomCreatedBy", fields: [createdBy], references: [id]) // ✅ Fixed
  userRooms     UserRoom[]
  messages      Message[]

}

// ─── Enums ───────────────────────────────────────────────

enum Tag {
  VIP
  VVIP
  REGULAR
}

enum EmployeeRole {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum RoomType {
  DIRECT  // ✅ Added — 1-on-1 chat
  GROUP   // ✅ Added — group chat
}

enum MessageType {
  TEXT    // ✅ Added
  IMAGE   // ✅ Added
  FILE    // ✅ Added
}


model Conversation {
  id                 Int      @id @default(autoincrement())
  organizationId     Int
  contactId          Int      @unique
  roomId             Int      @unique
  createdBy          Int


  // ✅ Add these directly
  lastMessage        String?
  lastMessageAt      DateTime?
  lastMessageType    MessageType?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id])
  contact       Contact      @relation(fields: [contactId], references: [id])
  room          Room         @relation(fields: [roomId], references: [id])

}